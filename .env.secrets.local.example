# GARAGE LINK 開発シークレット — テンプレート（Git OK）
# コピー: cp .env.secrets.local.example .env.secrets.local → 値を埋める → pnpm sync:env

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- GARAGE LINK アプリ ---
APP_ENCRYPTION_KEY=

# Vercel Cron 認証（車検案内ジョブ・解約データ削除ジョブ共通）
CRON_SECRET=
# 本番 URL（デプロイ後）: https://garage-link.tech
NEXT_PUBLIC_APP_URL=http://localhost:3001

# --- Stripe（テストモード）---
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=

# Stripe Price ID（pnpm stripe:setup-test）
STRIPE_PRICE_STARTER=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PRO=

# Stripe Price ID（pnpm stripe:setup-test:llink）
STRIPE_PRICE_LLINK_BASIC=
STRIPE_PRICE_LLINK_AUTO=

# --- Stripe（本番・未使用）---
STRIPE_LIVE_PUBLISHABLE_KEY=
STRIPE_LIVE_SECRET_KEY=
STRIPE_LIVE_WEBHOOK_SECRET=

# --- LINE ---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- L-LINK ---
# 本番 URL（デプロイ後）: https://llink.tech
NEXT_PUBLIC_L_LINK_APP_URL=http://localhost:3002

# --- 将来用 ---
VERCEL_TOKEN=
SENTRY_DSN=
RESEND_API_KEY=
