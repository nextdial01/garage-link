# GARAGE LINK environment variables
#
# 注意:
# - NEXT_PUBLIC_ から始まるものはブラウザに公開されます。
# - SUPABASE_SERVICE_ROLE_KEY は絶対にフロントで使わないでください。
# - LINE_CHANNEL_SECRET / LINE_CHANNEL_ACCESS_TOKEN は画面やログに出さないでください。
# - APP_ENCRYPTION_KEY はSecret暗号化用です。32文字以上、または32byteのbase64/hexを設定してください。
# - .env.local はGitにコミットしないでください。

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Administrator security gate cookie signing key. Use a strong server-only value.
GARAGE_LOGIN_SECURITY_SECRET=

# Cloudflare Turnstile bot protection for login and signup.
NEXT_PUBLIC_ENABLE_BOT_PROTECTION=true
NEXT_PUBLIC_BOT_PROTECTION_SITE_KEY=
BOT_PROTECTION_SECRET_KEY=
SUPABASE_AUTH_CAPTCHA_SECRET=

# LINE
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_WEBHOOK_DISABLE_ENV_SECRET_FALLBACK=false

# Security
APP_ENCRYPTION_KEY=
WEBHOOK_SIGNING_SECRET=

# E2E Test
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
E2E_EMAIL=
E2E_PASSWORD=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
