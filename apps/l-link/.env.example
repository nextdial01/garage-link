# L-Link local/staging environment variables
# Do not commit real values in .env.local.

NEXT_PUBLIC_L_LINK_APP_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key. Never expose this as NEXT_PUBLIC_*.
L_LINK_SUPABASE_SERVICE_ROLE_KEY=

# Optional local/staging company fallback for webhook and admin verification.
L_LINK_DEMO_COMPANY_ID=

# Secret encryption key. Use a strong 32+ byte value in staging/production.
L_LINK_APP_ENCRYPTION_KEY=

# LINE test account credentials. Server-side only.
L_LINK_LINE_CHANNEL_SECRET=
L_LINK_LINE_CHANNEL_ACCESS_TOKEN=
L_LINK_LINE_TEST_USER_ID=
L_LINK_WEBHOOK_BASE_URL=
