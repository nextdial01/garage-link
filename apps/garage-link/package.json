{
  "name": "@apps/garage-link",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:security",
    "test:security": "playwright test -c playwright.security.config.ts",
    "test:billing": "playwright test -c playwright.security.config.ts tests/security/garage-billing.test.ts",
    "test:e2e:billing": "node scripts/run-billing-e2e.mjs",
    "test:line-link-s2s": "node scripts/check-line-link-s2s.mjs",
    "test:l-link-inquiry-s2s": "node scripts/check-l-link-inquiry-s2s.mjs",
    "test:inquiry-response-management": "node scripts/check-inquiry-response-management.mjs",
    "test:line-link-s2s-ack": "node scripts/check-line-link-s2s-ack.mjs",
    "test:e2e": "playwright test",
    "qa:provision": "node scripts/provision-qa-account.mjs",
